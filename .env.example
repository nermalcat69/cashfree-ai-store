# Turso Database
# Get URL: turso db show --url <database-name>
# Get token: turso db tokens create <database-name>
TURSO_DATABASE_URL=libsql://your-database-name-your-org.turso.io
TURSO_AUTH_TOKEN=your-auth-token-here

# Admin Panel
# Password for the /admin panel
ADMIN_PASSWORD=your-admin-password-here

# AES-256-GCM Encryption Key (must be exactly 32 characters)
ENCRYPTION_KEY=dUfALJme4doiSlc7kkcKIy7YBpkYYWzS

# Cashfree (test/sandbox credentials)
# Get from: dashboard.cashfree.com > Payment Gateway > Developers > API Keys (switch to Test mode)
CASHFREE_APP_ID=your-cashfree-app-id
CASHFREE_SECRET_KEY=your-cashfree-secret-key

# Google Gemini (for AI chat agent)
# Get from: aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
